# ================================================
# ELECTRON VISION - Environment Variables Template
# ================================================
# IMPORTANT: Copy this file to .env and fill in your values
# DO NOT share your .env file!
# Security: chmod 600 .env after creating

# ================================================
# 1️⃣ Server Settings
# ================================================
NODE_ENV=development
PORT=3000
HTTPS_PORT=443
APP_URL=http://localhost:3000
FORCE_HTTPS=false
SITE_URL=http://localhost:3000
COOKIE_DOMAIN=

# ================================================
# 2️⃣ Database
# ================================================
DATABASE_PATH=./database.db

# ================================================
# 3️⃣ Security Keys (REQUIRED - Generate secure random strings)
# ================================================
# Generate at: https://generate-random.org/secure-random-string
# Minimum: 64 characters for secrets, 32 for encryption
SESSION_SECRET=your-64-character-session-secret-here
JWT_SECRET=your-64-character-jwt-secret-here
REFRESH_SECRET=your-64-character-refresh-secret-here
ENCRYPTION_KEY=your-32-character-encryption-key

# ================================================
# 4️⃣ Admin Panel Security
# ================================================
# Unique path for admin panel (generated from this secret)
ADMIN_SECRET=your-admin-panel-secret-key
# Comma-separated IP addresses for admin access (optional)
# ADMIN_IP_WHITELIST=192.168.1.1,10.0.0.1
# Bind session to IP (may cause issues with dynamic IPs)
ENABLE_IP_BINDING=false

# ================================================
# 5️⃣ Email (SMTP)
# ================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# ================================================
# 6️⃣ Stripe Payment
# ================================================
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ================================================
# 7️⃣ Telegram Bot
# ================================================
# Get from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_ADMIN_CHAT_ID=your-chat-id
TELEGRAM_GROUP_CHAT_ID=your-group-id
TELEGRAM_NOTIFICATIONS_ENABLED=true
TELEGRAM_NOTIFY_BOOKINGS=true
TELEGRAM_NOTIFY_PAYMENTS=true
TELEGRAM_NOTIFY_USERS=true
TELEGRAM_NOTIFY_ERRORS=true

# ================================================
# 8️⃣ Security Settings
# ================================================
ACCOUNT_LOCKOUT_DURATION=1800
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW=900

# ================================================
# 9️⃣ WAF (Web Application Firewall)
# ================================================
# WAF threshold for blocking requests
WAF_THRESHOLD=10
MAX_THREAT_SCORE=100
# Duration in seconds for temporary blocks
BLOCK_DURATION=3600
# Auto-block if threat score exceeds this
AUTO_BLOCK_THRESHOLD=50
# Rate limiting
MAX_REQUESTS_PER_MINUTE=120
MAX_CONCURRENT=50

# ================================================
# 🔟 Bot Detection & DDoS Protection
# ================================================
BOT_MAX_REQUESTS=100
BOT_MAX_CONCURRENT=30
BOT_BLOCK_DURATION=3600

# ================================================
# 1️⃣1️⃣ Monitoring & Alerts
# ================================================
MONITOR_INTERVAL=60000
LOG_RETENTION=30
# Alert thresholds
ALERT_RPM=200
ALERT_ERROR_RATE=10
ALERT_THREAT_SCORE=50
ALERT_FAILED_LOGINS=20
ENABLE_TELEGRAM_ALERTS=true

# ================================================
# 1️⃣2️⃣ Logging & Monitoring
# ================================================
LOG_LEVEL=info
ENABLE_FILE_LOGGING=true
LOG_DIR=./logs

# ================================================
# 1️⃣3️⃣ SSL/TLS Configuration
# ================================================
# Paths to SSL certificates (required in production)
SSL_KEY_PATH=./ssl/server.key
SSL_CERT_PATH=./ssl/server.crt
SSL_CA_PATH=./ssl/ca.crt

# ================================================
# 1️⃣4️⃣ CORS Settings
# ================================================
ALLOWED_ORIGINS=http://localhost:3000

# ================================================
# 1️⃣5️⃣ Other Settings
# ================================================
TIMEZONE=Asia/Damascus
DEFAULT_LANGUAGE=ar
DEFAULT_CURRENCY=USD
BUSINESS_NAME=ELECTRON VISION
